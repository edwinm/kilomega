{
	"name": "kilomega",
	"version": "1.0.5",
	"description": "Get the right metric unit prefix for a certain bit or byte amount.",
	"license": "MIT",
	"module": "kilomega.js",
	"main": "kilomega.common.js",
	"types": "kilomega.d.ts",
	"sideEffects": false,
	"scripts": {
		"build": "npx babel kilomega.js -o kilomega.common.js",
		"test": "npx jest",
		"coveralls": "jest --coverage && cat ./coverage/lcov.info | coveralls",
		"example": "node example/example.js"
	},
	"keywords": [
		"front-end",
		"backend",
		"metric",
		"si",
		"iec",
		"prefix",
		"kilo",
		"mega",
		"giga",
		"tera"
	],
	"author": {
		"name": "Edwin Martin",
		"email": "edwin@bitstorm.org",
		"url": "https://bitstorm.org/"
	},
	"files": [
		"kilomega.js",
		"kilomega.common.js",
		"kilomega.d.ts"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/edwinm/kilomega.git"
	},
	"devDependencies": {
		"@babel/cli": "^7.28.6",
		"@babel/core": "^7.29.0",
		"@babel/plugin-transform-modules-commonjs": "^7.28.6",
		"jest": "^30.3.0",
		"webpack": "^5.105.4",
		"webpack-cli": "^7.0.2"
	}
}
